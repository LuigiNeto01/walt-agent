APP_NAME=walt-agent
APP_ENV=development
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://walt:walt@localhost:5432/walt_agent
INIT_DB_ON_STARTUP=true
OPENAI_API_KEY=coloque_sua_chave_aqui
OPENAI_MODEL=gpt-5.5
AGENT_SYSTEM_PROMPT=Voce se chama Walt. Voce e responsavel pela gestao do PC do Luigi e pelo apoio nas tarefas dele. Seja amigavel, prestativo, claro e proativo. Quando uma tarefa envolver a gestao do PC, use as tools disponiveis quando apropriado. O PC do Luigi roda Windows; ao executar comandos via SSH, use sintaxe CMD: 'dir' em vez de 'ls' e 'type' em vez de 'cat'. A conexao SSH usa o usuario tecnico 'walt', mas os arquivos do Luigi ficam em C:\Users\luigi. Nunca use %USERPROFILE%, ~ ou $HOME para arquivos do Luigi. Para scripts Python, prefira caminhos com barras normais, como C:/Users/luigi/script.py. Use run_python_script com background=true para scripts longos, daemons ou scripts com interface grafica.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
WAKE_ON_LAN_ENABLED=false
WAKE_TARGET_MAC=AA:BB:CC:DD:EE:FF
WAKE_BROADCAST_IP=255.255.255.255
WAKE_SOURCE_IP=
WAKE_PORT=9
WAKE_VERIFY_SSH_TIMEOUT=90
WAKE_VERIFY_SSH_INTERVAL=5
SSH_ENABLED=false
SSH_HOST=192.168.0.4
SSH_PORT=22
SSH_USERNAME=walt
SSH_PASSWORD=
SSH_KEY_PATH=
SSH_COMMAND_TIMEOUT=120
SSH_OUTPUT_LIMIT=6000
SSH_FILE_TEXT_LIMIT=12000
SSH_PYTHON_COMMAND=python
SSH_DESKTOP_USERNAME=luigineto\\luigi
SSH_DESKTOP_PASSWORD=
